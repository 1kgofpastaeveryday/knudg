# Local self-host development defaults.
# Copy this file to .env and replace values for your environment.

DATABASE_URL=postgresql://knudg_migration:knudg_migration@localhost:54329/knudg
KNUDG_OPERATOR_TOKEN=dev-local-token
KNUDG_API_URL=http://127.0.0.1:8765
KNUDG_API_BASE_URL=http://127.0.0.1:8765

# Optional hosted profile. Do not commit real tokens or private endpoints.
# For Greencloud closed-launch publishing, replace the local URL above with
# the current reviewed API origin from deployment-local operator docs.
KNUDG_PROFILE=local

# Optional LLM judge for the backend final filter.
# Keep real keys in local environment/secrets only.
NVIDIA_API_KEY=
KNUDG_FINAL_FILTER_NVIDIA_MODEL=z-ai/glm-5.1
KNUDG_FINAL_FILTER_TIMEOUT_SECONDS=180
