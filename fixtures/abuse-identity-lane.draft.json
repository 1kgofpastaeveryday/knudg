{
  "schema_version": "abuse-identity-lane-v0",
  "status": "blocked",
  "lane_id": "abuse_identity_enforcement",
  "identity_storage": {
    "raw_identity_values": "forbidden_in_fixture",
    "protected_fingerprints": "required_before_real_data",
    "real_subject_rows": "none"
  },
  "operation_model": {
    "mode": "simulation_only",
    "real_enforcement_enabled": false,
    "normalized_outward_response": "generic_no_match_disclosure",
    "appeal_recovery_required_for": ["suspend", "ban"],
    "transitions": [
      {"action": "warn", "real_effect_enabled": false, "requires_audit_event": true},
      {"action": "rate_limit", "real_effect_enabled": false, "requires_audit_event": true},
      {"action": "hold_for_review", "real_effect_enabled": false, "requires_audit_event": true},
      {"action": "suspend", "real_effect_enabled": false, "requires_audit_event": true},
      {"action": "ban", "real_effect_enabled": false, "requires_audit_event": true},
      {"action": "appeal", "real_effect_enabled": false, "requires_audit_event": true},
      {"action": "reinstate", "real_effect_enabled": false, "requires_audit_event": true},
      {"action": "revoke", "real_effect_enabled": false, "requires_audit_event": true},
      {"action": "purge", "real_effect_enabled": false, "requires_audit_event": true}
    ]
  },
  "allowed_actions": [
    "warn",
    "rate_limit",
    "hold_for_review",
    "suspend",
    "ban",
    "appeal",
    "reinstate",
    "revoke",
    "purge"
  ],
  "forbidden_surfaces": [
    "retrieval",
    "actual_experience_storage",
    "raw_detail_escrow",
    "public_card",
    "aggregate_report",
    "b2b_dashboard",
    "b2b_respondent_portal",
    "company_store_dashboard",
    "public_candidate_conversion",
    "respondent_inquiry",
    "export",
    "ranking_feature"
  ],
  "audit_requirements": [
    "case_reason",
    "purpose_binding",
    "actor_identity",
    "decision_digest",
    "appeal_path",
    "reinstatement_path",
    "no_b2b_identity_disclosure"
  ],
  "audit_event_mapping": {
    "preflight_required_events": ["case_opened", "identity_signal_reviewed"],
    "transition_events": [
      {"action": "warn", "audit_event_type": "account_warned"},
      {"action": "rate_limit", "audit_event_type": "account_rate_limited"},
      {"action": "hold_for_review", "audit_event_type": "submission_held"},
      {"action": "suspend", "audit_event_type": "account_suspended"},
      {"action": "ban", "audit_event_type": "account_banned"},
      {"action": "appeal", "audit_event_type": "appeal_opened"},
      {"action": "reinstate", "audit_event_type": "reinstated"},
      {"action": "revoke", "audit_event_type": "artifact_revoked"},
      {"action": "purge", "audit_event_type": "artifact_purged"}
    ]
  },
  "blocked_until": [
    {
      "gate": "PR-006",
      "reason": "Core intake safety must exist before real abuse submissions are evaluated."
    },
    {
      "gate": "TNS-001",
      "reason": "Trust-and-safety audit schema must exist before real identity signals are stored."
    }
  ]
}
