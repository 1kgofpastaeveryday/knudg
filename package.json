{
  "name": "knudg",
  "version": "0.1.0",
  "description": "Self-hostable agent experience infrastructure for reusable solved paths, failed paths, and environment traps.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/1kgofpastaeveryday/knudg.git"
  },
  "bugs": {
    "url": "https://github.com/1kgofpastaeveryday/knudg/issues"
  },
  "homepage": "https://knudg.com",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "py": "node scripts/run-python.js",
    "setup:python": "node scripts/install-python-deps.js",
    "test": "node scripts/run-python.js -m pytest tests/test_knudg_closed_api.py tests/test_knudg_live_agent.py tests/test_task_profile_schema.py tests/test_knudg_client_config.py",
    "deploy:lp": "npx --yes wrangler@4.90.0 deploy --message \"LP deploy\"",
    "deploy:lp:candidate": "npx --yes wrangler@4.90.0 versions upload --message \"LP candidate\"",
    "deploy:lp:dry-run": "npx --yes wrangler@4.90.0 deploy --dry-run",
    "deploy:lp:list": "npx --yes wrangler@4.90.0 deployments list",
    "rollback:lp": "npx --yes wrangler@4.90.0 rollback --name knudg-site --message \"Rollback LP deploy\" --yes",
    "package:frontend": "node scripts/package-frontend.js",
    "check:lp": "node scripts/check-knudg-layout.js",
    "public:release-check": "node scripts/run-python.js scripts/validate_public_release.py",
    "secret:scan": "node scripts/run-python.js scripts/scan_secrets.py",
    "smoke:lp": "powershell -ExecutionPolicy Bypass -File scripts/smoke-knudg-site.ps1 -BaseUrl https://knudg.com",
    "dev:closed-api": "node scripts/run-python.js scripts/knudg_closed_api.py",
    "dev:frontend": "node scripts/run-python.js scripts/knudg_local_frontend.py",
    "knudgctl": "node scripts/run-python.js scripts/knudgctl.py",
    "post:private-card": "node scripts/run-python.js scripts/knudg_post_private_card.py",
    "task-profile": "node scripts/run-python.js scripts/knudg_task_profile.py",
    "domain:lookup": "node scripts/run-python.js -m pytest tests/test_domain_policy_lookup_migration.py",
    "domain:policies": "node scripts/run-python.js -m pytest tests/test_domain_policy_registry.py tests/test_task_profile_schema.py tests/test_knudg_task_profile_builder.py"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "wrangler": "4.99.0"
  }
}
