{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.local/schemas/auth-verifier-gate.schema.json",
  "title": "PR-004 Auth Verifier Gate Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "gate_id", "local_hs256", "non_local_profile", "negative_tests", "blocked_until"],
  "properties": {
    "schema_version": {"const": "auth-verifier-gate-v0"},
    "status": {"enum": ["draft_scaffold", "ready_for_review", "accepted"]},
    "gate_id": {"const": "PR-004"},
    "local_hs256": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_environments", "production_enabled", "team_or_staging_enabled", "ci_assertion"],
      "properties": {
        "allowed_environments": {
          "type": "array",
          "items": {"const": "local"},
          "uniqueItems": true
        },
        "production_enabled": {"const": false},
        "team_or_staging_enabled": {"const": false},
        "ci_assertion": {"type": "string", "pattern": "^ci:[A-Za-z0-9_.:/@-]{3,160}$"}
      }
    },
    "non_local_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_type",
        "issuer_binding",
        "audience_binding",
        "resource_indicator_binding",
        "sender_constrained_proof",
        "nonce_replay_store",
        "key_rotation",
        "outage_behavior"
      ],
      "properties": {
        "profile_type": {"enum": ["unset", "asymmetric_jwks", "kms_vault_verify"]},
        "issuer_binding": {"type": "boolean"},
        "audience_binding": {"type": "boolean"},
        "resource_indicator_binding": {"type": "boolean"},
        "sender_constrained_proof": {"enum": ["unset", "dpop", "mtls", "accepted_equivalent"]},
        "nonce_replay_store": {"type": "boolean"},
        "key_rotation": {"type": "boolean"},
        "outage_behavior": {"enum": ["fail_closed", "last_known_safe_for_readonly", "unset"]}
      }
    },
    "negative_tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "hs256_rejected_non_local",
          "alg_none_rejected",
          "wrong_audience_rejected",
          "wrong_issuer_rejected",
          "stale_key_rejected",
          "stale_nonce_rejected",
          "proof_key_mismatch_rejected",
          "cross_resource_replay_rejected",
          "rls_call_sites_unchanged"
        ]
      },
      "uniqueItems": true
    },
    "blocked_until": {
      "type": "array",
      "items": {
        "enum": [
          "asymmetric_or_kms_profile_accepted",
          "sender_constrained_profile_accepted",
          "nonce_replay_store_implemented",
          "key_rotation_tests_pass",
          "negative_auth_tests_pass",
          "environment_assertions_pass",
          "request_context_backend_swap_tested"
        ]
      },
      "uniqueItems": true
    }
  }
}
