{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.com/schemas/b2b-respondent-portal-request-v0.schema.json",
  "title": "Knudg B2B Respondent Portal Request v0",
  "type": "object",
  "required": [
    "schema_version",
    "request_class",
    "objective_item",
    "surface",
    "status",
    "source_public_candidate",
    "respondent_scope",
    "response_draft",
    "required_gates",
    "blocked_until",
    "output_contract",
    "respondent_visibility_contract",
    "portal_view_contract",
    "respondent_action_contract",
    "surface_enablement",
    "forbidden_outputs",
    "result_contract"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "b2b-respondent-portal-request-v0"},
    "request_class": {"type": "string", "const": "preflight_only"},
    "objective_item": {"type": "integer", "const": 10},
    "surface": {"type": "string", "const": "b2b_respondent_portal"},
    "status": {"type": "string", "const": "blocked"},
    "source_public_candidate": {
      "type": "object",
      "required": ["domain", "candidate_digest", "payload_digest", "public_serving_enabled"],
      "additionalProperties": false,
      "properties": {
        "domain": {"type": "string", "const": "public_experience_candidate"},
        "candidate_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "payload_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "public_serving_enabled": {"type": "boolean", "const": false}
      }
    },
    "respondent_scope": {
      "type": "object",
      "required": ["entity_type", "entity_public_name", "identity_verification_status", "contact_channel_available"],
      "additionalProperties": false,
      "properties": {
        "entity_type": {"type": "string", "enum": ["company", "place", "service"]},
        "entity_public_name": {"type": "string", "minLength": 1, "maxLength": 160},
        "identity_verification_status": {"type": "string", "const": "not_verified_preflight"},
        "contact_channel_available": {"type": "boolean", "const": false}
      }
    },
    "response_draft": {
      "type": "object",
      "required": [
        "draft_digest",
        "draft_kind",
        "contains_raw_source",
        "contains_submitter_identity",
        "contains_device_or_network_signal",
        "contains_protected_fingerprint",
        "contains_reidentification_hint",
        "response_available"
      ],
      "additionalProperties": false,
      "properties": {
        "draft_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "draft_kind": {"type": "string", "const": "redacted_response_outline"},
        "contains_raw_source": {"type": "boolean", "const": false},
        "contains_submitter_identity": {"type": "boolean", "const": false},
        "contains_device_or_network_signal": {"type": "boolean", "const": false},
        "contains_protected_fingerprint": {"type": "boolean", "const": false},
        "contains_reidentification_hint": {"type": "boolean", "const": false},
        "response_available": {"type": "boolean", "const": false}
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["ED-005", "NO_DISCLOSURE_NEGATIVE_TESTS", "RESPONDENT_POLICY", "MODERATION_WORKFLOW"]}
    },
    "blocked_until": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["ED-005", "NO_DISCLOSURE_NEGATIVE_TESTS", "RESPONDENT_POLICY", "MODERATION_WORKFLOW"]}
    },
    "output_contract": {
      "type": "object",
      "required": ["requested_outputs", "withheld_outputs"],
      "additionalProperties": false,
      "properties": {
        "requested_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["redacted_public_candidate_summary", "redacted_response_outline", "subject_public_name", "claim_type"]
          }
        },
        "withheld_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/forbidden_output"}
        }
      }
    },
    "respondent_visibility_contract": {
      "type": "object",
      "required": [
        "visibility_state",
        "visible_fields",
        "withheld_fields",
        "identity_disclosure",
        "raw_detail_disclosure",
        "moderation_disclosure",
        "response_submission_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "visibility_state": {"type": "string", "const": "not_available_preflight"},
        "visible_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "subject_public_name",
              "redacted_public_candidate_summary",
              "claim_type",
              "redacted_response_outline"
            ]
          }
        },
        "withheld_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/forbidden_output"}
        },
        "identity_disclosure": {"type": "string", "const": "none"},
        "raw_detail_disclosure": {"type": "string", "const": "none"},
        "moderation_disclosure": {"type": "string", "const": "policy_status_only"},
        "response_submission_policy": {"type": "string", "const": "disabled_until_gates_pass"}
      }
    },
    "portal_view_contract": {
      "type": "object",
      "required": [
        "view_model_kind",
        "view_model_state",
        "route_allocation",
        "access_token_issued",
        "server_render_enabled",
        "contains_submit_control",
        "contains_contact_channel"
      ],
      "additionalProperties": false,
      "properties": {
        "view_model_kind": {"type": "string", "const": "redacted_respondent_preview"},
        "view_model_state": {"type": "string", "const": "model_only_not_served"},
        "route_allocation": {"type": "string", "const": "none"},
        "access_token_issued": {"type": "boolean", "const": false},
        "server_render_enabled": {"type": "boolean", "const": false},
        "contains_submit_control": {"type": "boolean", "const": false},
        "contains_contact_channel": {"type": "boolean", "const": false}
      }
    },
    "respondent_action_contract": {
      "type": "object",
      "required": ["allowed_actions", "disabled_actions", "action_token_issued"],
      "additionalProperties": false,
      "properties": {
        "allowed_actions": {
          "type": "array",
          "maxItems": 0,
          "items": {"type": "string"}
        },
        "disabled_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "submit_response",
              "upload_raw_detail",
              "request_submitter_identity",
              "message_submitter",
              "claim_business_profile",
              "open_dashboard"
            ]
          }
        },
        "action_token_issued": {"type": "boolean", "const": false}
      }
    },
    "surface_enablement": {
      "type": "object",
      "required": [
        "portal_enabled",
        "b2b_delivery_enabled",
        "response_submission_enabled",
        "public_serving_enabled",
        "identity_processing_enabled",
        "raw_detail_escrow_enabled",
        "dashboard_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "portal_enabled": {"type": "boolean", "const": false},
        "b2b_delivery_enabled": {"type": "boolean", "const": false},
        "response_submission_enabled": {"type": "boolean", "const": false},
        "public_serving_enabled": {"type": "boolean", "const": false},
        "identity_processing_enabled": {"type": "boolean", "const": false},
        "raw_detail_escrow_enabled": {"type": "boolean", "const": false},
        "dashboard_enabled": {"type": "boolean", "const": false}
      }
    },
    "forbidden_outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/forbidden_output"}
    },
    "result_contract": {
      "type": "object",
      "required": [
        "command_effect",
        "opens_portal",
        "delivers_to_b2b",
        "makes_response_available",
        "opens_public_surface",
        "serves_dashboard",
        "performs_identity_processing",
        "stores_raw_detail"
      ],
      "additionalProperties": false,
      "properties": {
        "command_effect": {"type": "string", "const": "preflight_only"},
        "opens_portal": {"type": "boolean", "const": false},
        "delivers_to_b2b": {"type": "boolean", "const": false},
        "makes_response_available": {"type": "boolean", "const": false},
        "opens_public_surface": {"type": "boolean", "const": false},
        "serves_dashboard": {"type": "boolean", "const": false},
        "performs_identity_processing": {"type": "boolean", "const": false},
        "stores_raw_detail": {"type": "boolean", "const": false}
      }
    }
  },
  "$defs": {
    "forbidden_output": {
      "type": "string",
      "enum": [
        "submitter_identity",
        "raw_source_material",
        "device_or_network_signal",
        "reidentification_hint",
        "protected_fingerprint",
        "raw_review_body",
        "private_selection_status",
        "staff_identity",
        "non_public_operational_detail",
        "source_metadata",
        "raw_moderation_evidence",
        "escrow_ciphertext",
        "escrow_handle",
        "escrow_key_material",
        "reviewer_private_note",
        "non_public_operational_detail",
        "respondent_visible_user_attribution"
      ]
    }
  }
}
