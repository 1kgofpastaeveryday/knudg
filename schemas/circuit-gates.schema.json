{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.local/schemas/circuit-gates.schema.json",
  "title": "Operational Circuit Gate Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "decision_id", "families", "enablement"],
  "properties": {
    "schema_version": {"const": "circuit-gates-v0"},
    "status": {"enum": ["draft_scaffold", "ready_for_review", "accepted"]},
    "decision_id": {"const": "DEC-015"},
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "family",
          "normal_store",
          "emergency_store",
          "postgres_unavailable_behavior",
          "stale_emergency_behavior",
          "auto_clear_allowed",
          "strictest_state_wins",
          "owner_role",
          "runbook_id"
        ],
        "properties": {
          "family": {
            "enum": [
              "auth_revocation_data_integrity_backup",
              "public_wedge_publication",
              "landing_route_denylist",
              "vector_rerank_cost",
              "noncritical_writes_admission"
            ]
          },
          "normal_store": {"enum": ["operational_circuits", "host_config"]},
          "emergency_store": {
            "enum": [
              "signed_emergency_deny_manifest",
              "signed_rollout_disable_config",
              "edge_proxy_deny_rule",
              "signed_feature_disable_config",
              "signed_admission_pause_config"
            ]
          },
          "postgres_unavailable_behavior": {
            "enum": [
              "fail_closed",
              "publication_search_disabled",
              "serve_inert_static_or_404_410",
              "disable_dependency_exact_fts_or_no_suggestion",
              "pause_or_reject_idempotently"
            ]
          },
          "stale_emergency_behavior": {
            "enum": [
              "remain_closed_page_operator",
              "remain_disabled_no_auto_clear",
              "keep_deny_until_probe",
              "keep_disabled_until_owner_review",
              "keep_paused_no_background_retries"
            ]
          },
          "auto_clear_allowed": {"type": "boolean"},
          "strictest_state_wins": {"const": true},
          "owner_role": {"type": "string", "pattern": "^role:[A-Za-z0-9_-]{3,80}$"},
          "runbook_id": {"type": "string", "pattern": "^RB-[A-Z0-9-]{3,20}$"}
        }
      }
    },
    "enablement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["live_mutation_enabled", "public_publication_enabled", "blocked_until"],
      "properties": {
        "live_mutation_enabled": {"const": false},
        "public_publication_enabled": {"const": false},
        "blocked_until": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "circuit_ddl_implemented",
              "audit_events_implemented",
              "operator_authz_implemented",
              "emergency_manifest_verifier_implemented",
              "strictest_state_selection_tested",
              "outage_drills_pass"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
