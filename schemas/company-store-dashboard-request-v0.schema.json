{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.com/schemas/company-store-dashboard-request-v0.schema.json",
  "title": "Knudg Company Store Dashboard Request v0",
  "type": "object",
  "required": [
    "schema_version",
    "request_class",
    "objective_item",
    "surface",
    "status",
    "dashboard_subject",
    "aggregate_signal_request",
    "disclosure_policy",
    "aggregate_privacy_contract",
    "review_integrity_contract",
    "dashboard_display_contract",
    "dashboard_delivery_contract",
    "required_gates",
    "forbidden_outputs",
    "output_contract",
    "surface_enablement",
    "result_contract",
    "blocked_until"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "company-store-dashboard-request-v0"},
    "request_class": {"type": "string", "const": "preflight_only"},
    "objective_item": {"type": "integer", "const": 13},
    "surface": {"type": "string", "const": "company_store_dashboard"},
    "status": {"type": "string", "const": "blocked"},
    "dashboard_subject": {
      "type": "object",
      "required": ["subject_type", "domain", "subject_public_name", "subject_ref_digest", "claim_scope"],
      "additionalProperties": false,
      "properties": {
        "subject_type": {"type": "string", "enum": ["company", "place", "service"]},
        "domain": {"type": "string", "const": "public_aggregate_signal"},
        "subject_public_name": {"type": "string", "minLength": 1, "maxLength": 160},
        "subject_ref_digest": {"$ref": "#/$defs/sha256_digest"},
        "claim_scope": {"type": "string", "enum": ["public_aggregate_signal", "company_place_service_signal"]}
      }
    },
    "aggregate_signal_request": {
      "type": "object",
      "required": [
        "aggregate_signal_available",
        "minimum_group_size_met",
        "single_observation_display_enabled",
        "negative_review_suppression_enabled",
        "review_suppression_surface_enabled",
        "manipulation_response_controls_enabled",
        "manipulation_review_enabled",
        "freshness_policy_accepted",
        "stale_signal_expiry_accepted"
      ],
      "additionalProperties": false,
      "properties": {
        "aggregate_signal_available": {"type": "boolean", "const": false},
        "minimum_group_size_met": {"type": "boolean", "const": false},
        "single_observation_display_enabled": {"type": "boolean", "const": false},
        "negative_review_suppression_enabled": {"type": "boolean", "const": false},
        "review_suppression_surface_enabled": {"type": "boolean", "const": false},
        "manipulation_response_controls_enabled": {"type": "boolean", "const": false},
        "manipulation_review_enabled": {"type": "boolean", "const": false},
        "freshness_policy_accepted": {"type": "boolean", "const": false},
        "stale_signal_expiry_accepted": {"type": "boolean", "const": false}
      }
    },
    "disclosure_policy": {
      "type": "object",
      "required": [
        "public_b2b_disclosure_policy_accepted",
        "respondent_inquiry_policy_accepted",
        "no_identity_leakage_tests_passed",
        "correction_takedown_workflow_accepted",
        "source_count_threshold_label",
        "allowed_display_units"
      ],
      "additionalProperties": false,
      "properties": {
        "public_b2b_disclosure_policy_accepted": {"type": "boolean", "const": false},
        "respondent_inquiry_policy_accepted": {"type": "boolean", "const": false},
        "no_identity_leakage_tests_passed": {"type": "boolean", "const": false},
        "correction_takedown_workflow_accepted": {"type": "boolean", "const": false},
        "source_count_threshold_label": {"type": "string", "pattern": "^private-threshold:[A-Za-z0-9_.:-]{3,120}$"},
        "allowed_display_units": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["redacted_aggregate_summary", "trend_bucket", "freshness_bucket", "response_status_summary"]
          }
        }
      }
    },
    "aggregate_privacy_contract": {
      "type": "object",
      "required": [
        "aggregation_mode",
        "minimum_source_count_policy_accepted",
        "cell_suppression_required",
        "drilldown_to_source_allowed",
        "segment_breakdown_allowed",
        "confidence_and_freshness_labels_required"
      ],
      "additionalProperties": false,
      "properties": {
        "aggregation_mode": {"type": "string", "const": "aggregate_only_preflight"},
        "minimum_source_count_policy_accepted": {"type": "boolean", "const": false},
        "cell_suppression_required": {"type": "boolean", "const": true},
        "drilldown_to_source_allowed": {"type": "boolean", "const": false},
        "segment_breakdown_allowed": {"type": "boolean", "const": false},
        "confidence_and_freshness_labels_required": {"type": "boolean", "const": true}
      }
    },
    "review_integrity_contract": {
      "type": "object",
      "required": [
        "favorability_neutral_processing_required",
        "negative_review_suppression_allowed",
        "respondent_self_service_suppression_allowed",
        "manipulation_checks_required",
        "manipulation_response_controls_allowed",
        "correction_takedown_policy_accepted"
      ],
      "additionalProperties": false,
      "properties": {
        "favorability_neutral_processing_required": {"type": "boolean", "const": true},
        "negative_review_suppression_allowed": {"type": "boolean", "const": false},
        "respondent_self_service_suppression_allowed": {"type": "boolean", "const": false},
        "manipulation_checks_required": {"type": "boolean", "const": true},
        "manipulation_response_controls_allowed": {"type": "boolean", "const": false},
        "correction_takedown_policy_accepted": {"type": "boolean", "const": false}
      }
    },
    "dashboard_display_contract": {
      "type": "object",
      "required": [
        "view_model_state",
        "display_mode",
        "single_observation_display_allowed",
        "raw_detail_display_allowed",
        "identity_state_display_allowed",
        "escrow_artifact_display_allowed",
        "ranking_or_sorting_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "view_model_state": {"type": "string", "const": "model_only_not_served"},
        "display_mode": {"type": "string", "const": "aggregate_preview_only"},
        "single_observation_display_allowed": {"type": "boolean", "const": false},
        "raw_detail_display_allowed": {"type": "boolean", "const": false},
        "identity_state_display_allowed": {"type": "boolean", "const": false},
        "escrow_artifact_display_allowed": {"type": "boolean", "const": false},
        "ranking_or_sorting_enabled": {"type": "boolean", "const": false}
      }
    },
    "dashboard_delivery_contract": {
      "type": "object",
      "required": [
        "route_allocation",
        "access_token_issued",
        "api_serving_enabled",
        "export_download_enabled",
        "b2b_delivery_enabled",
        "public_serving_enabled",
        "dashboard_snapshot_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "route_allocation": {"type": "string", "const": "none"},
        "access_token_issued": {"type": "boolean", "const": false},
        "api_serving_enabled": {"type": "boolean", "const": false},
        "export_download_enabled": {"type": "boolean", "const": false},
        "b2b_delivery_enabled": {"type": "boolean", "const": false},
        "public_serving_enabled": {"type": "boolean", "const": false},
        "dashboard_snapshot_enabled": {"type": "boolean", "const": false}
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "AGGREGATE_SIGNAL_POLICY",
          "PUBLIC_B2B_DISCLOSURE_POLICY",
          "MODERATION_WORKFLOW",
          "NO_IDENTITY_LEAKAGE_TESTS",
          "MIN_SOURCE_COUNT_POLICY",
          "MANIPULATION_RESISTANCE_POLICY",
          "NO_SINGLE_OBSERVATION_DISPLAY_TESTS",
          "NO_SUPPRESSION_SURFACE_TESTS",
          "CORRECTION_TAKEDOWN_POLICY",
          "AGGREGATE_PRIVACY_THRESHOLD_POLICY",
          "FAIR_REVIEW_PRESENTATION_POLICY",
          "DASHBOARD_DISPLAY_POLICY",
          "NO_ESCROW_ARTIFACT_DISPLAY_TESTS",
          "DASHBOARD_EXPORT_DOWNLOAD_POLICY"
        ]
      }
    },
    "forbidden_outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/forbidden_output"}
    },
    "output_contract": {
      "type": "object",
      "required": ["requested_outputs", "withheld_outputs"],
      "additionalProperties": false,
      "properties": {
        "requested_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["redacted_dashboard_preflight_status", "preflight_blocked_reason", "digest_only_reference"]
          }
        },
        "withheld_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/forbidden_output"}
        }
      }
    },
    "surface_enablement": {
      "type": "object",
      "required": [
        "dashboard_enabled",
        "dashboard_serving_enabled",
        "aggregate_signal_query_enabled",
        "single_observation_display_enabled",
        "public_serving_enabled",
        "b2b_delivery_enabled",
        "respondent_portal_enabled",
        "identity_processing_enabled",
        "raw_detail_escrow_enabled",
        "retrieval_enabled",
        "export_enabled",
        "ranking_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "dashboard_enabled": {"type": "boolean", "const": false},
        "dashboard_serving_enabled": {"type": "boolean", "const": false},
        "aggregate_signal_query_enabled": {"type": "boolean", "const": false},
        "single_observation_display_enabled": {"type": "boolean", "const": false},
        "public_serving_enabled": {"type": "boolean", "const": false},
        "b2b_delivery_enabled": {"type": "boolean", "const": false},
        "respondent_portal_enabled": {"type": "boolean", "const": false},
        "identity_processing_enabled": {"type": "boolean", "const": false},
        "raw_detail_escrow_enabled": {"type": "boolean", "const": false},
        "retrieval_enabled": {"type": "boolean", "const": false},
        "export_enabled": {"type": "boolean", "const": false},
        "ranking_enabled": {"type": "boolean", "const": false}
      }
    },
    "result_contract": {
      "type": "object",
      "required": [
        "command_effect",
        "serves_dashboard",
        "creates_dashboard_view",
        "queries_aggregate_signal",
        "shows_single_observation",
        "suppresses_negative_reviews",
        "suppresses_or_hides_reviews",
        "opens_public_surface",
        "delivers_to_b2b",
        "opens_respondent_portal",
        "performs_identity_processing",
        "stores_raw_detail",
        "makes_retrievable",
        "exports_dashboard_data",
        "writes_audit_event"
      ],
      "additionalProperties": false,
      "properties": {
        "command_effect": {"type": "string", "const": "preflight_only"},
        "serves_dashboard": {"type": "boolean", "const": false},
        "creates_dashboard_view": {"type": "boolean", "const": false},
        "queries_aggregate_signal": {"type": "boolean", "const": false},
        "shows_single_observation": {"type": "boolean", "const": false},
        "suppresses_negative_reviews": {"type": "boolean", "const": false},
        "suppresses_or_hides_reviews": {"type": "boolean", "const": false},
        "opens_public_surface": {"type": "boolean", "const": false},
        "delivers_to_b2b": {"type": "boolean", "const": false},
        "opens_respondent_portal": {"type": "boolean", "const": false},
        "performs_identity_processing": {"type": "boolean", "const": false},
        "stores_raw_detail": {"type": "boolean", "const": false},
        "makes_retrievable": {"type": "boolean", "const": false},
        "exports_dashboard_data": {"type": "boolean", "const": false},
        "writes_audit_event": {"type": "boolean", "const": false}
      }
    },
    "blocked_until": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/blocker"}
    }
  },
  "$defs": {
    "sha256_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "forbidden_output": {
      "type": "string",
      "enum": [
        "submitter_identity",
        "raw_source_material",
        "raw_review_body",
        "device_or_network_signal",
        "reidentification_hint",
        "protected_fingerprint",
        "private_selection_status",
        "staff_identity",
        "source_metadata",
        "raw_moderation_evidence",
        "escrow_ciphertext",
        "escrow_handle",
        "escrow_key_material",
        "account_identifier",
        "match_status",
        "individual_claim",
        "single_observation_detail",
        "reviewer_private_note",
        "non_public_operational_detail"
      ]
    },
    "blocker": {
      "type": "object",
      "required": ["gate", "reason"],
      "additionalProperties": false,
      "properties": {
        "gate": {"type": "string", "pattern": "^[A-Z0-9_-]+$"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 240}
      }
    }
  }
}
