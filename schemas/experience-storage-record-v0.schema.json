{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.com/schemas/experience-storage-record-v0.schema.json",
  "title": "Knudg Experience Storage Record v0",
  "type": "object",
  "required": [
    "schema_version",
    "record_class",
    "domain",
    "subject",
    "storage_state",
    "consent",
    "redacted_experience",
    "source_controls",
    "surface_controls",
    "audit"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "experience-storage-record-v0"},
    "record_class": {"type": "string", "const": "redacted_private_experience_record"},
    "domain": {"type": "string", "enum": ["career_private", "place_service_experience"]},
    "subject": {
      "type": "object",
      "required": ["type", "public_name", "aliases", "entity_name_public_allowed", "private_person_refs"],
      "additionalProperties": false,
      "properties": {
        "type": {"type": "string", "enum": ["company", "place", "service"]},
        "public_name": {"type": "string", "minLength": 1, "maxLength": 160},
        "aliases": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        },
        "entity_name_public_allowed": {"type": "boolean", "const": true},
        "private_person_refs": {
          "type": "array",
          "maxItems": 0,
          "items": {"type": "string"}
        }
      }
    },
    "storage_state": {
      "type": "object",
      "required": ["mode", "activation_required", "database_write_enabled", "record_visible_to_retrieval"],
      "additionalProperties": false,
      "properties": {
        "mode": {"type": "string", "enum": ["contract_only_pre_storage", "stored_private_redacted"]},
        "activation_required": {"type": "boolean"},
        "database_write_enabled": {"type": "boolean"},
        "record_visible_to_retrieval": {"type": "boolean", "const": false}
      }
    },
    "consent": {
      "type": "object",
      "required": [
        "capture_notice_shown",
        "revocation_supported",
        "publication_consent",
        "b2b_contact_consent",
        "dashboard_aggregation_consent",
        "private_retention_consent_proof"
      ],
      "additionalProperties": false,
      "properties": {
        "capture_notice_shown": {"type": "boolean", "const": true},
        "revocation_supported": {"type": "boolean", "const": true},
        "publication_consent": {"type": "boolean", "const": false},
        "b2b_contact_consent": {"type": "boolean", "const": false},
        "dashboard_aggregation_consent": {"type": "boolean", "const": false},
        "private_retention_consent_proof": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": [
                "consent_id",
                "handoff_id",
                "challenge_id",
                "card_id",
                "card_version_id",
                "artifact_digest",
                "policy_version",
                "policy_digest",
                "challenge_digest",
                "handoff_digest"
              ],
              "additionalProperties": false,
              "properties": {
                "consent_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
                "handoff_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
                "challenge_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
                "card_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
                "card_version_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
                "artifact_digest": {"type": "string", "pattern": "^(sha256:)?[a-f0-9]{64}$"},
                "policy_version": {"type": "string", "minLength": 1, "maxLength": 120},
                "policy_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
                "challenge_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
                "handoff_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
              }
            }
          ]
        }
      }
    },
    "redacted_experience": {
      "type": "object",
      "required": [
        "title",
        "summary",
        "observations",
        "subjective_impressions",
        "disallowed_detail_classes",
        "private_selection_status_present",
        "raw_quotes_present",
        "exact_dates_present",
        "private_person_present"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {"type": "string", "minLength": 8, "maxLength": 120},
        "summary": {"type": "string", "minLength": 20, "maxLength": 600},
        "observations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {"type": "string", "minLength": 8, "maxLength": 240}
        },
        "subjective_impressions": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string", "minLength": 8, "maxLength": 240}
        },
        "disallowed_detail_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "selection_status",
              "private_message",
              "private_person_identity",
              "exact_timestamp",
              "raw_source_material",
              "protected_identity_signal",
              "device_or_network_signal"
            ]
          }
        },
        "private_selection_status_present": {"type": "boolean", "const": false},
        "raw_quotes_present": {"type": "boolean", "const": false},
        "exact_dates_present": {"type": "boolean", "const": false},
        "private_person_present": {"type": "boolean", "const": false}
      }
    },
    "source_controls": {
      "type": "object",
      "required": [
        "raw_source_retention",
        "raw_detail_escrow_ref",
        "raw_source_available_to_model",
        "source_digest"
      ],
      "additionalProperties": false,
      "properties": {
        "raw_source_retention": {"type": "string", "const": "none"},
        "raw_detail_escrow_ref": {"type": "null"},
        "raw_source_available_to_model": {"type": "boolean", "const": false},
        "source_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "surface_controls": {
      "type": "object",
      "required": [
        "retrieval_policy",
        "public_candidate_conversion_enabled",
        "public_serving_enabled",
        "b2b_delivery_enabled",
        "identity_processing_enabled",
        "raw_detail_escrow_enabled",
        "dashboard_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "retrieval_policy": {"type": "string", "const": "explicit_or_contextual"},
        "public_candidate_conversion_enabled": {"type": "boolean", "const": false},
        "public_serving_enabled": {"type": "boolean", "const": false},
        "b2b_delivery_enabled": {"type": "boolean", "const": false},
        "identity_processing_enabled": {"type": "boolean", "const": false},
        "raw_detail_escrow_enabled": {"type": "boolean", "const": false},
        "dashboard_enabled": {"type": "boolean", "const": false}
      }
    },
    "audit": {
      "type": "object",
      "required": ["actor_ref", "created_at", "redaction_digest", "redaction_notes"],
      "additionalProperties": false,
      "properties": {
        "actor_ref": {"type": "string", "pattern": "^(synthetic-actor|operator-private):[A-Za-z0-9_.:-]{3,120}$"},
        "created_at": {"type": "string", "pattern": "^(fixture-time|operator-time):[A-Za-z0-9_.:-]{8,80}$"},
        "redaction_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "redaction_notes": {"type": "string", "minLength": 20, "maxLength": 240}
      }
    }
  }
}
