{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.com/schemas/experience-surface-activation-request-v0.schema.json",
  "title": "Knudg Experience Surface Activation Request v0",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "requested_surface",
    "requested_operation",
    "objective_item",
    "requested_domains",
    "requested_enablement",
    "gate_evidence",
    "output_contract",
    "preflight_effect"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "experience-surface-activation-request-v0"},
    "request_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.:-]{6,120}$"},
    "requested_surface": {"$ref": "#/$defs/surface_key"},
    "requested_operation": {
      "type": "string",
      "enum": [
        "enable_actual_experience_storage",
        "convert_public_candidate",
        "open_b2b_respondent_portal",
        "enable_abuse_identity_ban_operations",
        "enable_raw_detail_escrow",
        "open_company_store_dashboard"
      ]
    },
    "objective_item": {"type": "integer", "minimum": 8, "maximum": 13},
    "requested_domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/domain_key"}
    },
    "requested_enablement": {"$ref": "#/$defs/enablement_request"},
    "gate_evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/gate_evidence"}
    },
    "output_contract": {
      "type": "object",
      "required": [
        "requested_outputs",
        "allowed_outputs",
        "redaction_profile",
        "no_raw_identity_output",
        "no_raw_source_output"
      ],
      "additionalProperties": false,
      "properties": {
        "requested_outputs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/output_class"}
        },
        "allowed_outputs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/output_class"}
        },
        "redaction_profile": {
          "type": "string",
          "enum": [
            "career_private_redacted",
            "place_service_redacted",
            "public_candidate_redacted",
            "aggregate_signal_redacted",
            "protected_escrow_no_display",
            "abuse_identity_simulation_only"
          ]
        },
        "no_raw_identity_output": {"const": true},
        "no_raw_source_output": {"const": true}
      }
    },
    "preflight_effect": {
      "type": "object",
      "required": [
        "command_effect",
        "writes_real_data",
        "creates_card",
        "indexes",
        "opens_public_surface",
        "performs_identity_processing",
        "stores_raw_detail",
        "serves_dashboard"
      ],
      "additionalProperties": false,
      "properties": {
        "command_effect": {"const": "preflight_only"},
        "writes_real_data": {"const": false},
        "creates_card": {"const": false},
        "indexes": {"const": false},
        "opens_public_surface": {"const": false},
        "performs_identity_processing": {"const": false},
        "stores_raw_detail": {"const": false},
        "serves_dashboard": {"const": false}
      }
    }
  },
  "$defs": {
    "domain_key": {
      "type": "string",
      "enum": [
        "career_private",
        "place_service_experience",
        "public_experience_candidate",
        "public_aggregate_signal"
      ]
    },
    "surface_key": {
      "type": "string",
      "enum": [
        "actual_experience_storage",
        "public_candidate_conversion",
        "b2b_respondent_portal",
        "abuse_identity_ban_operations",
        "raw_detail_escrow",
        "company_store_dashboard"
      ]
    },
    "enablement_request": {
      "type": "object",
      "required": [
        "real_data_ingest_enabled",
        "public_serving_enabled",
        "b2b_delivery_enabled",
        "identity_processing_enabled",
        "raw_detail_escrow_enabled",
        "dashboard_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "real_data_ingest_enabled": {"type": "boolean"},
        "public_serving_enabled": {"type": "boolean"},
        "b2b_delivery_enabled": {"type": "boolean"},
        "identity_processing_enabled": {"type": "boolean"},
        "raw_detail_escrow_enabled": {"type": "boolean"},
        "dashboard_enabled": {"type": "boolean"}
      }
    },
    "gate_evidence": {
      "type": "object",
      "required": ["gate", "status", "evidence_ref"],
      "additionalProperties": false,
      "properties": {
        "gate": {"type": "string", "pattern": "^[A-Z0-9_-]+$"},
        "status": {"type": "string", "enum": ["missing", "draft", "passed", "accepted"]},
        "evidence_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9_.:/#-]+$"
        }
      }
    },
    "output_class": {
      "type": "string",
      "enum": [
        "redacted_subject_name",
        "redacted_experience_summary",
        "aggregate_count",
        "aggregate_sentiment",
        "moderation_status",
        "appeal_status",
        "submitter_identity",
        "raw_source_material",
        "device_or_network_signal",
        "reidentification_hint",
        "private_selection_status",
        "staff_identity",
        "protected_fingerprint",
        "raw_review_body",
        "non_public_operational_detail",
        "source_metadata",
        "raw_moderation_evidence",
        "escrow_ciphertext",
        "escrow_handle",
        "escrow_key_material",
        "reviewer_private_note"
      ]
    }
  }
}
