{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.local/schemas/launch-gate-manifest.schema.json",
  "title": "Launch Gate Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "generated_for", "gates"],
  "properties": {
    "schema_version": {"const": "launch-gate-manifest-v0"},
    "status": {"enum": ["draft_all_closed", "ready_for_review", "accepted"]},
    "generated_for": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment", "release_ref", "generated_at"],
      "properties": {
        "environment": {"enum": ["local", "private_alpha", "team_alpha", "public_pilot", "production"]},
        "release_ref": {"type": "string", "pattern": "^[A-Za-z0-9._:/@-]{1,160}$"},
        "generated_at": {"type": "string", "format": "date-time"}
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate_id",
          "owner_role",
          "status",
          "authority",
          "public_safe_status_label",
          "private_threshold_ref",
          "required_fixture_refs",
          "ci_result_refs",
          "evidence_refs",
          "rollback_target",
          "stale_review_behavior",
          "blocking_dependents"
        ],
        "properties": {
          "gate_id": {
            "enum": [
              "PR-001",
              "PR-002",
              "PR-003",
              "PR-004",
              "PR-005",
              "PR-005A",
              "PR-006",
              "PR-007",
              "non_synthetic_body_persistence_gate"
            ]
          },
          "owner_role": {"type": "string", "pattern": "^role:[A-Za-z0-9_-]{3,80}$"},
          "status": {"enum": ["closed", "open", "expired", "withdrawn"]},
          "authority": {
            "type": "object",
            "additionalProperties": false,
            "required": ["document_path", "accepted_revision"],
            "properties": {
              "document_path": {"type": "string", "pattern": "^(README\\.md|docs/|backlog/)[A-Za-z0-9_./-]+\\.md$"},
              "accepted_revision": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9._:/@-]{1,160}$"}
            }
          },
          "public_safe_status_label": {
            "enum": [
              "closed_no_evidence",
              "closed_draft_scaffold_only",
              "closed_evidence_expired",
              "open_evidence_current",
              "withdrawn"
            ]
          },
          "private_threshold_ref": {
            "type": ["string", "null"],
            "pattern": "^private-threshold:[A-Za-z0-9_.:-]{3,120}$"
          },
          "required_fixture_refs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^(fixtures|schemas|tests)/[A-Za-z0-9_./-]+$"},
            "uniqueItems": true
          },
          "ci_result_refs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^ci:[A-Za-z0-9_.:/@-]{3,160}$"},
            "uniqueItems": true
          },
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^evidence:[A-Za-z0-9_.:/@-]{3,160}$"},
            "uniqueItems": true
          },
          "rollback_target": {"type": "string", "pattern": "^[A-Za-z0-9_.:/@-]{3,160}$"},
          "stale_review_behavior": {"enum": ["fail_closed", "withdraw_public_route", "keep_disabled", "quarantine"]},
          "blocking_dependents": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[A-Za-z0-9_.:-]{2,120}$"},
            "uniqueItems": true
          },
          "review_expires_at": {"type": ["string", "null"], "format": "date-time"}
        }
      }
    }
  }
}
