{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.local/schemas/m3-retrieval-gates.schema.json",
  "title": "M3 Retrieval Gate Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "exact_fts",
    "proof_profile",
    "protected_data_enablement"
  ],
  "properties": {
    "schema_version": {
      "const": "m3-retrieval-gates-v0"
    },
    "status": {
      "enum": ["draft_scaffold", "ready_for_review", "accepted"]
    },
    "exact_fts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_sql_fixture_id",
        "tokenizer_profile",
        "rank_formula",
        "abstention_threshold_label",
        "score_normalization",
        "replay_fixture_set_id",
        "baseline_set_id",
        "accepted_spec_artifact"
      ],
      "properties": {
        "canonical_sql_fixture_id": {"type": "string", "pattern": "^fixture_[A-Za-z0-9_-]{6,80}$"},
        "tokenizer_profile": {"type": "string", "enum": ["postgres-simple", "postgres-english", "unset"]},
        "rank_formula": {"type": "string", "enum": ["unset", "ts_rank_cd_plus_exact_v0"]},
        "abstention_threshold_label": {"type": "string", "pattern": "^threshold_[A-Za-z0-9_-]{6,80}$"},
        "score_normalization": {"type": "string", "enum": ["unset", "minmax_per_replay_band_v0"]},
        "replay_fixture_set_id": {"type": "string", "pattern": "^replay_[A-Za-z0-9_-]{6,80}$"},
        "baseline_set_id": {"type": "string", "pattern": "^baseline_[A-Za-z0-9_-]{6,80}$"},
        "accepted_spec_artifact": {"type": ["string", "null"], "pattern": "^docs/operations/evidence/[A-Za-z0-9_.-]+\\.json$"}
      }
    },
    "proof_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "status",
        "default_profile",
        "accepted_profile",
        "accepted_profile_artifact",
        "required_tests"
      ],
      "properties": {
        "decision_id": {"const": "DEC-014A"},
        "status": {"enum": ["open", "accepted"]},
        "default_profile": {"enum": ["DPoP", "mTLS", "HTTPS-only synthetic/public harness"]},
        "accepted_profile": {"type": ["string", "null"], "enum": ["DPoP", "mTLS", "other", null]},
        "accepted_profile_artifact": {"type": ["string", "null"], "pattern": "^docs/operations/evidence/[A-Za-z0-9_.-]+\\.json$"},
        "required_tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "audience_bound",
              "method_url_body_digest_signed",
              "nonce_replay_rejected",
              "stale_timestamp_rejected",
              "wrong_key_rejected",
              "cross_resource_replay_rejected",
              "refresh_token_absent"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "protected_data_enablement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "allowed_fixture_classes",
        "blocked_until"
      ],
      "properties": {
        "enabled": {"const": false},
        "allowed_fixture_classes": {
          "type": "array",
          "items": {"enum": ["synthetic", "public"]},
          "uniqueItems": true
        },
        "blocked_until": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "exact_fts_spec_accepted",
              "dec_014a_accepted",
              "auth_interop_tests_pass",
              "revocation_fence_tests_pass",
              "operator_circuit_runbook_pass"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
