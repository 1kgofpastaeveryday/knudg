{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.com/schemas/public-candidate-conversion-request-v0.schema.json",
  "title": "Knudg Public Candidate Conversion Request v0",
  "type": "object",
  "required": [
    "schema_version",
    "request_class",
    "objective_item",
    "surface",
    "status",
    "source_private_record",
    "new_public_candidate_artifact",
    "public_candidate_payload",
    "approval_path",
    "required_gates",
    "blocked_until",
    "output_contract",
    "surface_enablement",
    "forbidden_outputs",
    "result_contract"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "public-candidate-conversion-request-v0"},
    "request_class": {"type": "string", "const": "preflight_only"},
    "objective_item": {"type": "integer", "const": 9},
    "surface": {"type": "string", "const": "public_candidate_conversion"},
    "status": {"type": "string", "const": "blocked"},
    "source_private_record": {
      "type": "object",
      "required": [
        "domain",
        "record_digest",
        "record_id",
        "private_retention_consent_id",
        "private_record_mutation",
        "source_raw_retention",
        "source_retrieval_visible"
      ],
      "additionalProperties": false,
      "properties": {
        "domain": {"type": "string", "enum": ["career_private", "place_service_experience"]},
        "record_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "record_id": {"$ref": "#/$defs/uuid"},
        "private_retention_consent_id": {"$ref": "#/$defs/uuid"},
        "private_record_mutation": {"type": "string", "const": "forbidden"},
        "source_raw_retention": {"type": "string", "const": "none"},
        "source_retrieval_visible": {"type": "boolean", "const": false}
      }
    },
    "new_public_candidate_artifact": {
      "type": "object",
      "required": [
        "artifact_digest",
        "payload_digest",
        "domain",
        "subject_type",
        "claim_type",
        "evidence_strength",
        "redaction_level",
        "raw_source_retention",
        "stored_public_card"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "payload_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "domain": {"type": "string", "const": "public_experience_candidate"},
        "subject_type": {"type": "string", "enum": ["company", "place", "service"]},
        "claim_type": {"type": "string", "enum": ["factual_observation", "subjective_impression", "aggregate_summary", "unverified_report"]},
        "evidence_strength": {"type": "string", "enum": ["single_observation", "repeated_personal_observation", "corroborated", "public_source_supported", "operator_judgment"]},
        "redaction_level": {"type": "string", "const": "public_candidate_safe"},
        "raw_source_retention": {"type": "string", "const": "none"},
        "stored_public_card": {"type": "boolean", "const": false}
      }
    },
    "public_candidate_payload": {
      "type": "object",
      "required": [
        "schema_version",
        "subject_public_name",
        "redacted_public_candidate_summary",
        "public_observations",
        "public_subjective_impressions",
        "excluded_private_detail_classes",
        "source_attribution",
        "publication_state"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {"type": "string", "const": "public-experience-candidate-payload-v0"},
        "subject_public_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[^@\\\\]+$"
        },
        "redacted_public_candidate_summary": {
          "type": "string",
          "minLength": 40,
          "maxLength": 600,
          "pattern": "^[^@\\\\]+$"
        },
        "public_observations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {"type": "string", "minLength": 8, "maxLength": 240, "pattern": "^[^@\\\\]+$"}
        },
        "public_subjective_impressions": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string", "minLength": 8, "maxLength": 240, "pattern": "^[^@\\\\]+$"}
        },
        "excluded_private_detail_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/forbidden_output"}
        },
        "source_attribution": {"type": "string", "const": "redacted_private_experience_record"},
        "publication_state": {"type": "string", "const": "candidate_only_not_served"}
      }
    },
    "approval_path": {
      "type": "object",
      "required": [
        "exact_artifact_approval_required",
        "reviewer_publish_required",
        "consent_challenge_required",
        "approval_completed",
        "reviewer_publish_completed"
      ],
      "additionalProperties": false,
      "properties": {
        "exact_artifact_approval_required": {"type": "boolean", "const": true},
        "reviewer_publish_required": {"type": "boolean", "const": true},
        "consent_challenge_required": {"type": "boolean", "const": true},
        "approval_completed": {"type": "boolean", "const": false},
        "reviewer_publish_completed": {"type": "boolean", "const": false}
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["PR-003", "PR-005", "PR-006", "REVIEWER_PUBLISH"]}
    },
    "blocked_until": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["PR-003", "PR-005", "PR-006", "REVIEWER_PUBLISH"]}
    },
    "output_contract": {
      "type": "object",
      "required": ["requested_outputs", "withheld_outputs"],
      "additionalProperties": false,
      "properties": {
        "requested_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["redacted_public_candidate_summary", "subject_public_name", "claim_type", "evidence_strength"]
          }
        },
        "withheld_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/forbidden_output"}
        }
      }
    },
    "surface_enablement": {
      "type": "object",
      "required": [
        "conversion_enabled",
        "public_serving_enabled",
        "b2b_delivery_enabled",
        "identity_processing_enabled",
        "raw_detail_escrow_enabled",
        "dashboard_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "conversion_enabled": {"type": "boolean", "const": false},
        "public_serving_enabled": {"type": "boolean", "const": false},
        "b2b_delivery_enabled": {"type": "boolean", "const": false},
        "identity_processing_enabled": {"type": "boolean", "const": false},
        "raw_detail_escrow_enabled": {"type": "boolean", "const": false},
        "dashboard_enabled": {"type": "boolean", "const": false}
      }
    },
    "forbidden_outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/forbidden_output"}
    },
    "result_contract": {
      "type": "object",
      "required": [
        "command_effect",
        "creates_public_card",
        "mutates_private_record",
        "opens_public_surface",
        "delivers_to_b2b",
        "serves_dashboard",
        "stores_raw_detail"
      ],
      "additionalProperties": false,
      "properties": {
        "command_effect": {"type": "string", "const": "preflight_only"},
        "creates_public_card": {"type": "boolean", "const": false},
        "mutates_private_record": {"type": "boolean", "const": false},
        "opens_public_surface": {"type": "boolean", "const": false},
        "delivers_to_b2b": {"type": "boolean", "const": false},
        "serves_dashboard": {"type": "boolean", "const": false},
        "stores_raw_detail": {"type": "boolean", "const": false}
      }
    }
  },
  "$defs": {
    "forbidden_output": {
      "type": "string",
      "enum": [
        "submitter_identity",
        "raw_source_material",
        "private_selection_status",
        "staff_identity",
        "raw_review_body",
        "non_public_operational_detail",
        "device_or_network_signal",
        "reidentification_hint",
        "protected_fingerprint"
      ]
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    }
  }
}
