{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.com/schemas/raw-detail-escrow-request-v0.schema.json",
  "title": "Knudg Raw Detail Escrow Request v0",
  "type": "object",
  "required": [
    "schema_version",
    "request_class",
    "objective_item",
    "surface",
    "status",
    "source_context",
    "escrow_request",
    "escrow_policy_contract",
    "consent_revocation",
    "protected_storage",
    "cryptographic_envelope_contract",
    "reviewer_access_contract",
    "retention_purge_contract",
    "audit_echo_contract",
    "required_gates",
    "forbidden_outputs",
    "output_contract",
    "surface_enablement",
    "result_contract",
    "blocked_until"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "raw-detail-escrow-request-v0"},
    "request_class": {"type": "string", "const": "preflight_only"},
    "objective_item": {"type": "integer", "const": 12},
    "surface": {"type": "string", "const": "raw_detail_escrow"},
    "status": {"type": "string", "const": "blocked"},
    "source_context": {
      "type": "object",
      "required": ["domain", "source_record_digest", "redacted_artifact_digest", "raw_payload_digest"],
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string",
          "enum": ["career_private", "place_service_experience", "public_experience_candidate"]
        },
        "source_record_digest": {"$ref": "#/$defs/sha256_digest"},
        "redacted_artifact_digest": {"$ref": "#/$defs/sha256_digest"},
        "raw_payload_digest": {"$ref": "#/$defs/sha256_digest"}
      }
    },
    "escrow_request": {
      "type": "object",
      "required": [
        "reason",
        "mode",
        "raw_source_material",
        "raw_review_body",
        "escrow_handle_created",
        "encrypted_blob_created",
        "reviewer_access_enabled",
        "reviewer_lease_created",
        "decrypt_operation_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "reason": {"type": "string", "enum": ["human_review_required", "legal_review_required", "safety_review_required"]},
        "mode": {"type": "string", "const": "not_created"},
        "raw_source_material": {"type": "string", "const": "forbidden_in_fixture"},
        "raw_review_body": {"type": "string", "const": "forbidden_in_fixture"},
        "escrow_handle_created": {"type": "boolean", "const": false},
        "encrypted_blob_created": {"type": "boolean", "const": false},
        "reviewer_access_enabled": {"type": "boolean", "const": false},
        "reviewer_lease_created": {"type": "boolean", "const": false},
        "decrypt_operation_enabled": {"type": "boolean", "const": false}
      }
    },
    "escrow_policy_contract": {
      "type": "object",
      "required": [
        "purpose_binding",
        "allowed_review_reasons",
        "public_release_allowed",
        "b2b_release_allowed",
        "respondent_release_allowed",
        "model_training_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "purpose_binding": {"type": "string", "const": "intake_review_only"},
        "allowed_review_reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "enum": ["human_review_required", "legal_review_required", "safety_review_required"]}
        },
        "public_release_allowed": {"type": "boolean", "const": false},
        "b2b_release_allowed": {"type": "boolean", "const": false},
        "respondent_release_allowed": {"type": "boolean", "const": false},
        "model_training_allowed": {"type": "boolean", "const": false}
      }
    },
    "consent_revocation": {
      "type": "object",
      "required": [
        "required_scope",
        "trusted_consent_completion_enabled",
        "escrow_consent_completed",
        "revocation_supported_required",
        "purge_path_accepted",
        "ttl_policy_accepted"
      ],
      "additionalProperties": false,
      "properties": {
        "required_scope": {"type": "string", "const": "intake_review_escrow"},
        "trusted_consent_completion_enabled": {"type": "boolean", "const": false},
        "escrow_consent_completed": {"type": "boolean", "const": false},
        "revocation_supported_required": {"type": "boolean", "const": true},
        "purge_path_accepted": {"type": "boolean", "const": false},
        "ttl_policy_accepted": {"type": "boolean", "const": false}
      }
    },
    "protected_storage": {
      "type": "object",
      "required": [
        "encryption_profile",
        "key_management_profile",
        "key_material",
        "durable_storage_enabled",
        "backup_retention_enabled",
        "restore_quarantine_enabled",
        "access_audit_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "encryption_profile": {"type": "string", "const": "required_before_real_data"},
        "key_management_profile": {"type": "string", "enum": ["required_before_real_data", "not_implemented"]},
        "key_material": {"type": "string", "const": "forbidden_in_fixture"},
        "durable_storage_enabled": {"type": "boolean", "const": false},
        "backup_retention_enabled": {"type": "boolean", "const": false},
        "restore_quarantine_enabled": {"type": "boolean", "const": false},
        "access_audit_enabled": {"type": "boolean", "const": false}
      }
    },
    "cryptographic_envelope_contract": {
      "type": "object",
      "required": [
        "envelope_created",
        "aead_profile",
        "key_wrapping_profile",
        "key_separation_required",
        "aad_binds_source_and_consent",
        "nonce_uniqueness_required",
        "plaintext_digest_only_reference",
        "key_rotation_policy_accepted"
      ],
      "additionalProperties": false,
      "properties": {
        "envelope_created": {"type": "boolean", "const": false},
        "aead_profile": {"type": "string", "const": "required_before_real_data"},
        "key_wrapping_profile": {"type": "string", "const": "required_before_real_data"},
        "key_separation_required": {"type": "boolean", "const": true},
        "aad_binds_source_and_consent": {"type": "boolean", "const": true},
        "nonce_uniqueness_required": {"type": "boolean", "const": true},
        "plaintext_digest_only_reference": {"type": "boolean", "const": true},
        "key_rotation_policy_accepted": {"type": "boolean", "const": false}
      }
    },
    "reviewer_access_contract": {
      "type": "object",
      "required": [
        "step_up_required",
        "lease_mode",
        "lease_ttl_policy_accepted",
        "two_person_access_required_for_legal",
        "copy_export_allowed",
        "bulk_access_allowed",
        "access_reason_required"
      ],
      "additionalProperties": false,
      "properties": {
        "step_up_required": {"type": "boolean", "const": true},
        "lease_mode": {"type": "string", "const": "disabled_preflight_only"},
        "lease_ttl_policy_accepted": {"type": "boolean", "const": false},
        "two_person_access_required_for_legal": {"type": "boolean", "const": true},
        "copy_export_allowed": {"type": "boolean", "const": false},
        "bulk_access_allowed": {"type": "boolean", "const": false},
        "access_reason_required": {"type": "boolean", "const": true}
      }
    },
    "retention_purge_contract": {
      "type": "object",
      "required": [
        "retention_mode",
        "ttl_required_before_real_data",
        "revocation_purge_required",
        "backup_purge_required",
        "restore_quarantine_required",
        "purge_receipt_required",
        "legal_hold_policy_accepted"
      ],
      "additionalProperties": false,
      "properties": {
        "retention_mode": {"type": "string", "const": "no_retention_preflight"},
        "ttl_required_before_real_data": {"type": "boolean", "const": true},
        "revocation_purge_required": {"type": "boolean", "const": true},
        "backup_purge_required": {"type": "boolean", "const": true},
        "restore_quarantine_required": {"type": "boolean", "const": true},
        "purge_receipt_required": {"type": "boolean", "const": true},
        "legal_hold_policy_accepted": {"type": "boolean", "const": false}
      }
    },
    "audit_echo_contract": {
      "type": "object",
      "required": [
        "audit_reference_mode",
        "raw_in_audit",
        "raw_in_model_input",
        "raw_in_validator_errors",
        "raw_in_client_response",
        "raw_in_b2b_or_dashboard",
        "digest_fields_required"
      ],
      "additionalProperties": false,
      "properties": {
        "audit_reference_mode": {"type": "string", "const": "digest_only"},
        "raw_in_audit": {"type": "string", "const": "forbidden"},
        "raw_in_model_input": {"type": "string", "const": "forbidden"},
        "raw_in_validator_errors": {"type": "string", "const": "forbidden"},
        "raw_in_client_response": {"type": "string", "const": "forbidden"},
        "raw_in_b2b_or_dashboard": {"type": "string", "const": "forbidden"},
        "digest_fields_required": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["source_record_digest", "redacted_artifact_digest", "raw_payload_digest"]
          }
        }
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "PR-003",
          "PR-006",
          "PROTECTED_DATA_DURABILITY",
          "PURGE_PATH",
          "ESCROW_TTL_POLICY",
          "REVIEWER_ACCESS_POLICY",
          "NO_RAW_ECHO_NEGATIVE_TESTS",
          "KEY_PROFILE_ACCEPTED",
          "RAW_DETAIL_PURPOSE_BINDING",
          "CRYPTOGRAPHIC_ENVELOPE_PROFILE",
          "ACCESS_LEASE_POLICY",
          "RESTORE_BACKUP_PURGE_POLICY",
          "AUDIT_DIGEST_ONLY_POLICY"
        ]
      }
    },
    "forbidden_outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/forbidden_output"}
    },
    "output_contract": {
      "type": "object",
      "required": ["requested_outputs", "withheld_outputs"],
      "additionalProperties": false,
      "properties": {
        "requested_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["redacted_escrow_preflight_status", "preflight_blocked_reason", "digest_only_reference"]
          }
        },
        "withheld_outputs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/forbidden_output"}
        }
      }
    },
    "surface_enablement": {
      "type": "object",
      "required": [
        "raw_detail_escrow_enabled",
        "escrow_write_enabled",
        "encrypted_blob_storage_enabled",
        "reviewer_access_enabled",
        "decrypt_operation_enabled",
        "reviewer_lease_creation_enabled",
        "model_input_includes_raw",
        "validator_errors_include_raw",
        "audit_or_client_response_includes_raw",
        "real_data_ingest_enabled",
        "public_serving_enabled",
        "b2b_delivery_enabled",
        "identity_processing_enabled",
        "dashboard_enabled",
        "retrieval_enabled",
        "export_enabled",
        "ranking_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "raw_detail_escrow_enabled": {"type": "boolean", "const": false},
        "escrow_write_enabled": {"type": "boolean", "const": false},
        "encrypted_blob_storage_enabled": {"type": "boolean", "const": false},
        "reviewer_access_enabled": {"type": "boolean", "const": false},
        "decrypt_operation_enabled": {"type": "boolean", "const": false},
        "reviewer_lease_creation_enabled": {"type": "boolean", "const": false},
        "model_input_includes_raw": {"type": "boolean", "const": false},
        "validator_errors_include_raw": {"type": "boolean", "const": false},
        "audit_or_client_response_includes_raw": {"type": "boolean", "const": false},
        "real_data_ingest_enabled": {"type": "boolean", "const": false},
        "public_serving_enabled": {"type": "boolean", "const": false},
        "b2b_delivery_enabled": {"type": "boolean", "const": false},
        "identity_processing_enabled": {"type": "boolean", "const": false},
        "dashboard_enabled": {"type": "boolean", "const": false},
        "retrieval_enabled": {"type": "boolean", "const": false},
        "export_enabled": {"type": "boolean", "const": false},
        "ranking_enabled": {"type": "boolean", "const": false}
      }
    },
    "result_contract": {
      "type": "object",
      "required": [
        "command_effect",
        "stores_raw_detail",
        "creates_escrow_handle",
        "creates_encrypted_blob",
        "stores_key_material",
        "opens_reviewer_access",
        "creates_reviewer_lease",
        "decrypts_escrow",
        "sends_raw_to_model_input",
        "echoes_raw_in_validator_errors",
        "echoes_raw_in_audit_or_client_response",
        "opens_public_surface",
        "delivers_to_b2b",
        "serves_dashboard",
        "performs_identity_processing",
        "makes_retrievable",
        "exports_raw_detail",
        "writes_audit_event"
      ],
      "additionalProperties": false,
      "properties": {
        "command_effect": {"type": "string", "const": "preflight_only"},
        "stores_raw_detail": {"type": "boolean", "const": false},
        "creates_escrow_handle": {"type": "boolean", "const": false},
        "creates_encrypted_blob": {"type": "boolean", "const": false},
        "stores_key_material": {"type": "boolean", "const": false},
        "opens_reviewer_access": {"type": "boolean", "const": false},
        "creates_reviewer_lease": {"type": "boolean", "const": false},
        "decrypts_escrow": {"type": "boolean", "const": false},
        "sends_raw_to_model_input": {"type": "boolean", "const": false},
        "echoes_raw_in_validator_errors": {"type": "boolean", "const": false},
        "echoes_raw_in_audit_or_client_response": {"type": "boolean", "const": false},
        "opens_public_surface": {"type": "boolean", "const": false},
        "delivers_to_b2b": {"type": "boolean", "const": false},
        "serves_dashboard": {"type": "boolean", "const": false},
        "performs_identity_processing": {"type": "boolean", "const": false},
        "makes_retrievable": {"type": "boolean", "const": false},
        "exports_raw_detail": {"type": "boolean", "const": false},
        "writes_audit_event": {"type": "boolean", "const": false}
      }
    },
    "blocked_until": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/blocker"}
    }
  },
  "$defs": {
    "sha256_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "forbidden_output": {
      "type": "string",
      "enum": [
        "submitter_identity",
        "raw_source_material",
        "raw_review_body",
        "device_or_network_signal",
        "reidentification_hint",
        "protected_fingerprint",
        "private_selection_status",
        "staff_identity",
        "source_metadata",
        "raw_moderation_evidence",
        "escrow_ciphertext",
        "escrow_handle",
        "escrow_key_material",
        "reviewer_private_note",
        "non_public_operational_detail"
      ]
    },
    "blocker": {
      "type": "object",
      "required": ["gate", "reason"],
      "additionalProperties": false,
      "properties": {
        "gate": {"type": "string", "pattern": "^[A-Z0-9_-]+$"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 240}
      }
    }
  }
}
