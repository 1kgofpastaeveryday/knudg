{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.local/schemas/runbook-command-manifest.schema.json",
  "title": "Runbook Command Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "commands"],
  "properties": {
    "schema_version": {"const": "runbook-command-manifest-v0"},
    "status": {"enum": ["draft_scaffold", "ready_for_drill", "drill_passed"]},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command_id",
          "runbook_id",
          "command",
          "operator_role",
          "dry_run_behavior",
          "mutation_guard",
          "stable_exit_codes",
          "json_output_schema",
          "audit_event",
          "drill_transcript_status",
          "drill_transcript_path"
        ],
        "properties": {
          "command_id": {"type": "string", "pattern": "^cmd_[A-Za-z0-9_-]{6,80}$"},
          "runbook_id": {"type": "string", "pattern": "^RB-[A-Z0-9-]{3,20}$"},
          "command": {"type": "string", "pattern": "^knudgctl [A-Za-z0-9_ ./:< >-]+(?: --[A-Za-z0-9_-]+(?: <[A-Za-z0-9_-]+>)?)*$"},
          "operator_role": {"type": "string", "pattern": "^role:[A-Za-z0-9_-]{3,80}$"},
          "dry_run_behavior": {"enum": ["read_only", "required_for_mutation", "not_applicable"]},
          "mutation_guard": {"enum": ["none", "dry_run_or_apply_required", "not_configured_until_integration", "trusted_operator_only"]},
          "stable_exit_codes": {
            "type": "array",
            "minItems": 1,
            "items": {"enum": [0, 2, 3, 4]},
            "uniqueItems": true
          },
          "json_output_schema": {"type": "string", "pattern": "^schema:[A-Za-z0-9_.:-]{3,120}$"},
          "audit_event": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,120}$"},
          "drill_transcript_status": {"enum": ["missing", "attached", "passed"]},
          "drill_transcript_path": {"type": ["string", "null"], "pattern": "^docs/operations/drills/[A-Za-z0-9_.-]+\\.json$"}
        }
      }
    }
  }
}
