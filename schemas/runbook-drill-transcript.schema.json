{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.local/schemas/runbook-drill-transcript.schema.json",
  "title": "Runbook Drill Transcript",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "command_id", "command", "exit_code", "output_status"],
  "properties": {
    "schema_version": {"const": "runbook-drill-transcript-v0"},
    "status": {"enum": ["passed", "failed"]},
    "command_id": {"type": "string", "pattern": "^cmd_[A-Za-z0-9_-]{6,80}$"},
    "command": {"type": "string", "pattern": "^knudgctl "},
    "exit_code": {"enum": [0, 2, 3, 4]},
    "output_status": {"enum": ["ok", "not_configured", "usage_error", "unavailable"]}
  }
}
