{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knudg.com/schemas/trust-and-safety-audit-v0.schema.json",
  "title": "Knudg Trust And Safety Audit Gate v0",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "gate_id",
    "real_identity_processing_enabled",
    "operational_enablement",
    "covered_domains",
    "event_types",
    "required_event_fields",
    "synthetic_audit_event_contract",
    "synthetic_events",
    "identity_controls",
    "forbidden_disclosures",
    "blocked_until"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "trust-and-safety-audit-v0"},
    "status": {"type": "string", "enum": ["draft", "accepted"]},
    "gate_id": {"type": "string", "const": "TNS-001"},
    "real_identity_processing_enabled": {"type": "boolean", "const": false},
    "operational_enablement": {
      "type": "object",
      "required": [
        "real_ban_operations_enabled",
        "respondent_inquiry_enabled",
        "b2b_dashboard_enabled",
        "raw_detail_escrow_enabled",
        "public_candidate_publication_enabled",
        "public_candidate_conversion_enabled",
        "b2b_respondent_portal_enabled",
        "company_store_dashboard_enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "real_ban_operations_enabled": {"const": false},
        "respondent_inquiry_enabled": {"const": false},
        "b2b_dashboard_enabled": {"const": false},
        "raw_detail_escrow_enabled": {"const": false},
        "public_candidate_publication_enabled": {"const": false},
        "public_candidate_conversion_enabled": {"const": false},
        "b2b_respondent_portal_enabled": {"const": false},
        "company_store_dashboard_enabled": {"const": false}
      }
    },
    "covered_domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "technical_work",
          "personal_reasoning",
          "career_private",
          "place_service_experience",
          "public_experience_candidate",
          "public_aggregate_signal"
        ]
      }
    },
    "event_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["case_opened", "identity_signal_reviewed", "submission_held", "account_warned", "account_rate_limited", "account_suspended", "account_banned", "appeal_opened", "reinstated", "artifact_revoked", "artifact_purged"]
      }
    },
    "required_event_fields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["case_id", "actor_id", "purpose", "reason_class", "decision_digest", "subject_ref", "appeal_ref", "created_at"]
      }
    },
    "synthetic_audit_event_contract": {
      "type": "object",
      "required": [
        "case_id",
        "actor_id",
        "purpose",
        "reason_class",
        "decision_digest",
        "subject_ref",
        "appeal_ref",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "case_id": {"type": "string", "pattern": "^case:[A-Za-z0-9_.:-]{8,120}$"},
        "actor_id": {"type": "string", "pattern": "^actor:[A-Za-z0-9_.:-]{8,120}$"},
        "purpose": {
          "type": "string",
          "enum": ["abuse_preflight", "appeal_review", "artifact_revocation", "purge_verification"]
        },
        "reason_class": {
          "type": "string",
          "enum": ["spam", "brigading", "fake_experience", "harassment", "ban_evasion", "mistaken_identity", "policy_revocation"]
        },
        "decision_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "subject_ref": {"type": "string", "pattern": "^subject-ref:[A-Za-z0-9_.:-]{8,120}$"},
        "appeal_ref": {"type": ["string", "null"], "pattern": "^appeal-ref:[A-Za-z0-9_.:-]{8,120}$"},
        "created_at": {"type": "string", "pattern": "^fixture-time:[A-Za-z0-9_.:-]{8,80}$"}
      }
    },
    "synthetic_events": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "event_type",
          "case_id",
          "actor_id",
          "purpose",
          "reason_class",
          "decision_digest",
          "subject_ref",
          "appeal_ref",
          "created_at",
          "audit_events_projection"
        ],
        "additionalProperties": false,
        "properties": {
          "event_type": {
            "type": "string",
            "enum": ["case_opened", "identity_signal_reviewed", "submission_held", "account_warned", "account_rate_limited", "account_suspended", "account_banned", "appeal_opened", "reinstated", "artifact_revoked", "artifact_purged"]
          },
          "case_id": {"type": "string", "pattern": "^synthetic-case:[A-Za-z0-9_.:-]{3,120}$"},
          "actor_id": {"type": "string", "pattern": "^synthetic-actor:[A-Za-z0-9_.:-]{3,120}$"},
          "purpose": {
            "type": "string",
            "enum": ["abuse_preflight", "appeal_review", "artifact_revocation", "purge_verification"]
          },
          "reason_class": {
            "type": "string",
            "enum": ["spam", "brigading", "fake_experience", "harassment", "ban_evasion", "mistaken_identity", "policy_revocation"]
          },
          "decision_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "subject_ref": {"type": "string", "pattern": "^synthetic-subject:[A-Za-z0-9_.:-]{3,120}$"},
          "appeal_ref": {"type": "string", "pattern": "^synthetic-appeal:(none|[A-Za-z0-9_.:-]{3,120})$"},
          "created_at": {"type": "string", "pattern": "^fixture-time:[A-Za-z0-9_.:-]{8,80}$"},
          "audit_events_projection": {
            "type": "object",
            "required": ["action", "target_type", "reason_code", "sanitized_detail"],
            "additionalProperties": false,
            "properties": {
              "action": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,120}$"},
              "target_type": {"type": "string", "enum": ["tns_case", "tns_subject", "experience_artifact", "appeal"]},
              "reason_code": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,120}$"},
              "sanitized_detail": {"type": "string", "pattern": "^synthetic-detail:[A-Za-z0-9_.:-]{3,160}$"}
            }
          }
        }
      }
    },
    "identity_controls": {
      "type": "object",
      "required": ["raw_identity_values", "protected_fingerprints", "subject_rows"],
      "additionalProperties": false,
      "properties": {
        "raw_identity_values": {"type": "string", "const": "forbidden_in_fixture"},
        "protected_fingerprints": {"type": "string", "enum": ["required_before_real_data", "not_implemented"]},
        "subject_rows": {"type": "string", "const": "none"}
      }
    },
    "forbidden_disclosures": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "business_dashboard",
          "actual_experience_storage",
          "raw_detail_escrow",
          "respondent_inquiry",
          "b2b_respondent_portal",
          "company_store_dashboard",
          "public_candidate_conversion",
          "public_card",
          "retrieval_panel",
          "export",
          "ranking_feature"
        ]
      }
    },
    "blocked_until": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[A-Z0-9_-]+$"}
    }
  }
}
