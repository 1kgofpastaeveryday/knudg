{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "knudg-site",
  "compatibility_date": "2026-05-12",
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "routes": [
    {
      "pattern": "knudg.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./site",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
